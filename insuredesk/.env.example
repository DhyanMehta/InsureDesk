# ===================================
# InsureDesk Environment Configuration
# ===================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ===================
# 🔴 REQUIRED - Supabase Configuration
# ===================
# Get these from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL (format: https://xxxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Your Supabase anonymous/public key (starts with eyJhbGc...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# ===================
# 🟡 OPTIONAL - Redis Cache (Upstash)
# ===================
# Get these from: https://console.upstash.com/redis
# Redis dramatically improves performance (6-8x faster)
# If not set, app will use in-memory cache (slower but functional)

# Upstash Redis REST URL (format: https://xxxxx.upstash.io)
UPSTASH_REDIS_REST_URL=your_redis_url_here

# Upstash Redis REST token (starts with AXxxxx...)
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here


# ===================
# 🔵 OPTIONAL - Monitoring & Analytics
# ===================
# Uncomment and configure if you want error tracking and analytics

# Sentry DSN for error tracking (recommended for production)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Google Analytics ID (if you want usage analytics)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id_here


# ===================
# 🟢 DEVELOPMENT ONLY
# ===================
# These are automatically set by Next.js

# NODE_ENV=development  # Set to 'production' when deploying
# PORT=3000              # Development server port


# ===================
# 📝 SETUP INSTRUCTIONS
# ===================
#
# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Set up Supabase:
#    - Create account at https://supabase.com
#    - Create a new project
#    - Go to Settings > API
#    - Copy URL and anon key
#    - Run migrations from /migrations folder
#
# 3. (Optional) Set up Redis:
#    - Create account at https://upstash.com
#    - Create a Redis database
#    - Copy REST URL and token
#    - App will work without Redis (uses memory cache)
#
# 4. Test your setup:
#    npm run dev
#    Visit: http://localhost:3000/api/health
#
# 5. For production:
#    - Set NODE_ENV=production
#    - Verify all required variables are set
#    - Run: npm run build
#    - Deploy to Vercel/Netlify/your platform
#
# ===================
# 🔒 SECURITY NOTES
# ===================
#
# ✅ DO:
# - Keep .env.local secret
# - Use different keys for dev/production
# - Rotate keys regularly
# - Enable RLS policies in Supabase
#
# ❌ DON'T:
# - Commit .env.local to Git
# - Share keys in public channels
# - Use production keys in development
# - Expose backend keys to the client
#
