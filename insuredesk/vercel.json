{
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "installCommand": "npm install",
    "framework": "nextjs",
    "regions": [
        "iad1"
    ],
    "functions": {
        "app/api/**/*.js": {
            "memory": 1024,
            "maxDuration": 10
        },
        "app/api/**/*.ts": {
            "memory": 1024,
            "maxDuration": 10
        }
    },
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "s-maxage=60, stale-while-revalidate"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/keep-alive?secret=YOUR_CRON_SECRET_VALUE",
            "schedule": "0 0 */3 * *"
        }
    ]
}